generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         Int       @id @default(autoincrement())
  email      String    @unique
  password   String    @map("password_hash")
  name       String
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @default(now()) @updatedAt @map("updated_at")

  journalEntries JournalEntry[]
  dreamEntries   DreamEntry[]
  anxietyTriggers AnxietyTrigger[]
  beliefs         Belief[]
  goals           Goal[]
  protocols       Protocol[]
  identityVision  IdentityVision?
  datingProfile   DatingProfile?
  genomeUploads   GenomeUpload[]
  stories         Story[]
  people          Person[]
  jokes           Joke[]
  practiceSessions     PracticeSession[]
  conversationStarters ConversationStarter[]
  aiConversations      AiConversation[]
  healthIntakeEvents   HealthIntakeEvent[]
  dayPlanTemplate      DayPlanTemplate?
  dayPlans             DayPlan[]
}

model JournalEntry {
  id        Int       @id @default(autoincrement())
  userId    Int       @map("user_id")
  content   String
  mood      String?
  tags      String?
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @default(now()) @updatedAt @map("updated_at")
  user      User      @relation(fields: [userId], references: [id])
  stories   Story[]
}

model DreamEntry {
  id           Int       @id @default(autoincrement())
  userId       Int       @map("user_id")
  content      String
  title        String?   // optional short title e.g. "Flying over mountains"
  sleepQuality String?   @map("sleep_quality") // rested, restless, vivid, etc.
  tags         String?
  analysis     String?   // stored AI analysis JSON
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @default(now()) @updatedAt @map("updated_at")
  user         User      @relation(fields: [userId], references: [id])

  @@map("dream_entries")
}

model AnxietyTrigger {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  title     String
  category  String?
  intensity Int?     // 1-10
  notes     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
  user      User     @relation(fields: [userId], references: [id])

  @@map("anxiety_triggers")
}

model Belief {
  id            Int      @id @default(autoincrement())
  userId        Int      @map("user_id")
  currentBelief String   @map("current_belief")
  desiredBelief String   @map("desired_belief")
  changePlan    String?  @map("change_plan")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at")
  user          User     @relation(fields: [userId], references: [id])

  @@map("beliefs")
}

model Goal {
  id          Int       @id @default(autoincrement())
  userId      Int       @map("user_id")
  title       String
  description String?
  area        String?
  targetDate  DateTime? @map("target_date") @db.Date
  status      String    @default("active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at")
  user        User      @relation(fields: [userId], references: [id])

  @@map("goals")
}

model Protocol {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  title     String
  whenToUse String?  @map("when_to_use")
  steps     String?  // JSON array
  cadence   String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
  user      User     @relation(fields: [userId], references: [id])

  @@map("protocols")
}

model IdentityVision {
  id           Int      @id @default(autoincrement())
  userId       Int      @unique @map("user_id")
  vision       String?
  values       String?  // JSON array
  principles   String?  // JSON array
  traits       String?  // JSON array
  visionPoints String?  @map("vision_points") // JSON array
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at")
  user         User     @relation(fields: [userId], references: [id])

  @@map("identity_visions")
}

model DatingProfile {
  id                    Int      @id @default(autoincrement())
  userId                Int      @unique @map("user_id")
  shortTermRequirements String?  @map("short_term_requirements") // JSON
  longTermRequirements  String?  @map("long_term_requirements") // JSON
  selfReflectionAnswers String?  @map("self_reflection_answers") // JSON
  updatedAt             DateTime @default(now()) @updatedAt @map("updated_at")
  user                  User     @relation(fields: [userId], references: [id])

  @@map("dating_profiles")
}

model GenomeUpload {
  id           Int      @id @default(autoincrement())
  userId       Int      @map("user_id")
  originalName String   @map("original_name")
  storedName   String   @map("stored_name")
  mimeType     String?  @map("mime_type")
  sizeBytes    Int?     @map("size_bytes")
  createdAt    DateTime @default(now()) @map("created_at")
  user         User     @relation(fields: [userId], references: [id])

  @@map("genome_uploads")
}

model Story {
  id              Int       @id @default(autoincrement())
  userId          Int       @map("user_id")
  journalEntryId  Int?      @map("journal_entry_id")
  title           String
  content         String
  tone            String
  durationSeconds Int       @default(30) @map("duration_seconds")
  tags            String?
  timesTold       Int       @default(0) @map("times_told")
  successRating   Int?      @map("success_rating")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @default(now()) @updatedAt @map("updated_at")
  user            User      @relation(fields: [userId], references: [id])
  journalEntry    JournalEntry? @relation(fields: [journalEntryId], references: [id])
  practiceSessions     PracticeSession[]
  conversationStarters ConversationStarter[]
}

model PracticeSession {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  storyId   Int?     @map("story_id")
  sessionType String @map("session_type")
  feedback  String?
  rating    Int?
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id])
  story     Story?   @relation(fields: [storyId], references: [id])
}

model ConversationStarter {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  storyId   Int?     @map("story_id")
  question  String
  context   String?
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id])
  story     Story?   @relation(fields: [storyId], references: [id])
}

model Person {
  id                  Int      @id @default(autoincrement())
  userId              Int      @map("user_id")
  name                String
  relationship        String?
  howMet              String?  @map("how_met")
  interests           String?
  personalityTraits   String?  @map("personality_traits")
  conversationStyle   String?  @map("conversation_style")
  sharedExperiences   String?  @map("shared_experiences")
  storyPreferences    String?  @map("story_preferences")
  notes               String?
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @default(now()) @updatedAt @map("updated_at")
  user                User     @relation(fields: [userId], references: [id])
  textUploads         PersonTextUpload[]
  conversationTopics  PersonConversationTopic[]
  insideJokes         PersonInsideJoke[]
}

model PersonTextUpload {
  id        Int      @id @default(autoincrement())
  personId  Int      @map("person_id")
  label     String
  content   String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
  person    Person   @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@map("person_text_uploads")
}

model PersonConversationTopic {
  id        Int      @id @default(autoincrement())
  personId  Int      @map("person_id")
  topic     String
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
  person    Person   @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@map("person_conversation_topics")
}

model PersonInsideJoke {
  id        Int      @id @default(autoincrement())
  personId  Int      @map("person_id")
  joke      String
  context   String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
  person    Person   @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@map("person_inside_jokes")
}

model Joke {
  id           Int      @id @default(autoincrement())
  userId       Int      @map("user_id")
  title        String
  content      String
  category     String?
  difficulty   String?
  timesTold    Int      @default(0) @map("times_told")
  successRating Int?    @map("success_rating")
  notes        String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at")
  user         User     @relation(fields: [userId], references: [id])
}

model AiConversation {
  id        Int         @id @default(autoincrement())
  userId    Int         @map("user_id")
  personId  Int?        @map("person_id")
  title     String?
  summary   String?
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @default(now()) @updatedAt @map("updated_at")
  user      User        @relation(fields: [userId], references: [id])
  messages  AiMessage[]

  @@map("ai_conversations")
}

model AiMessage {
  id             Int            @id @default(autoincrement())
  conversationId Int            @map("conversation_id")
  role           String         // user | assistant | system
  content        String
  createdAt      DateTime       @default(now()) @map("created_at")
  conversation   AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  pins           AiMessagePin[]

  @@map("ai_messages")
}

model AiMessagePin {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  personId  Int      @map("person_id")
  messageId Int     @map("message_id")
  note      String?
  pinnedAt  DateTime @default(now()) @map("pinned_at")
  message   AiMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([userId, personId, messageId])
  @@map("ai_message_pins")
}

model HealthIntakeEvent {
  id         Int      @id @default(autoincrement())
  userId     Int?     @map("user_id")
  source     String?
  eventType  String?  @map("event_type")
  eventDate  String?  @map("event_date")
  payloadJson String @map("payload_json")
  createdAt  DateTime @default(now()) @map("created_at")
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("health_intake_events")
}

model DayPlanTemplate {
  id             Int      @id @default(autoincrement())
  userId         Int      @map("user_id")
  defaultStartTime String @default("08:00") @map("default_start_time")
  items          DayPlanTemplateItem[]
  user           User     @relation(fields: [userId], references: [id])
  dayPlans       DayPlan[]

  @@unique([userId])
  @@map("day_plan_templates")
}

model DayPlanTemplateItem {
  id             Int      @id @default(autoincrement())
  templateId     Int      @map("template_id")
  title          String
  defaultMinutes Int      @default(30) @map("default_minutes")
  sortOrder      Int      @default(0) @map("sort_order")
  template       DayPlanTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@map("day_plan_template_items")
}

model DayPlan {
  id          Int      @id @default(autoincrement())
  userId      Int      @map("user_id")
  date        DateTime @db.Date
  startTime   String   @map("start_time")
  templateId  Int?     @map("template_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")
  user        User     @relation(fields: [userId], references: [id])
  template    DayPlanTemplate? @relation(fields: [templateId], references: [id])
  items       DayPlanItem[]

  @@unique([userId, date])
  @@map("day_plans")
}

model DayPlanItem {
  id             Int      @id @default(autoincrement())
  dayPlanId      Int      @map("day_plan_id")
  title          String
  plannedMinutes Int      @map("planned_minutes")
  actualMinutes  Int?     @map("actual_minutes")
  completed      Boolean  @default(false)
  sortOrder      Int      @default(0) @map("sort_order")
  dayPlan        DayPlan  @relation(fields: [dayPlanId], references: [id], onDelete: Cascade)

  @@map("day_plan_items")
}
